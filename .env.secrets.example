# GitHub Actions CD 시크릿 설정 파일
# 이 파일을 복사 후 값을 채워 사용한다: cp .env.secrets.example .env.secrets
# .env.secrets는 gitignore 처리되어 있으므로 커밋되지 않는다.
# 설정 후 scripts/setup-github-secrets.sh 실행

# AWS 자격증명 (ECR push, SSM Parameter Store 접근용)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 개발 서버 SSH 접속 정보
DEV_SSH_HOST=
DEV_SSH_USER=ec2-user
DEV_SSH_PORT=22

# SSH 개인키 파일 경로 (PEM 파일 전체 내용을 시크릿으로 등록)
# 예: ~/.ssh/techtaurant-dev.pem
DEV_SSH_PRIVATE_KEY_PATH=
