# Application
APP_NAME=TechTaurant Main API
SERVER_PORT=8080
LOG_LEVEL=info

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=techtaurant
DB_USERNAME=root
DB_PASSWORD=1234

# OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
JWT_SECRET=
JWT_ACCESS_TOKEN_EXPIRE_MS=3600000
JWT_REFRESH_TOKEN_EXPIRE_MS=604800000

# OAuth2 Redirect
OAUTH2_SUCCESS_REDIRECT_URL=http://localhost:3000/oauth/callback
OAUTH2_FAILURE_REDIRECT_URL=http://localhost:3000/oauth/error

# CORS
# 허용할 Origin을 쉼표로 구분하여 지정
# 개발 환경: 프론트엔드 로컬 주소
# 프로덕션: 실제 도메인 (예: https://techtaurant.com)
# 주의: allowCredentials=true 설정으로 와일드카드(*) 사용 불가
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Cookie Settings
# COOKIE_SECURE: HTTPS에서만 쿠키 전송 (개발: false, 프로덕션: true)
# COOKIE_HTTP_ONLY: JavaScript에서 쿠키 접근 차단 (보안상 true 권장)
# COOKIE_SAME_SITE: CSRF 방지 (Strict, Lax, None)
# COOKIE_PATH: 쿠키 유효 경로
COOKIE_SECURE=false
COOKIE_HTTP_ONLY=true
COOKIE_SAME_SITE=Lax
COOKIE_PATH=/

# Swagger
# 개발 환경: http://localhost:8080
SWAGGER_BASE_URL=http://localhost:8080

# ── GitHub Actions CD 시크릿 ──────────────────────────────────────────────────
# 로컬 개발에는 불필요. scripts/setup-github-secrets.sh 실행 시에만 사용됨.

# AWS 자격증명 (ECR push, SSM Parameter Store 접근용)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# 개발 서버 SSH 접속 정보
DEV_SSH_HOST=
DEV_SSH_USER=ec2-user
DEV_SSH_PORT=22

# SSH 개인키 파일 경로 (PEM 파일 전체 내용을 시크릿으로 등록)
# 예: ~/.ssh/techtaurant-dev.pem
DEV_SSH_PRIVATE_KEY_PATH=
